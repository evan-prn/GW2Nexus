# ═══════════════════════════════════════════════════════════════════
# GW2Nexus — backend/.env.example
# Template de configuration Laravel 11
#
# 1. Copier ce fichier : cp .env.example .env
# 2. Générer APP_KEY  : docker compose exec laravel php artisan key:generate
# 3. Remplir DB_PASSWORD avec la même valeur que dans le .env racine
# ═══════════════════════════════════════════════════════════════════

# ─── Application ──────────────────────────────────────────────────
APP_NAME=GW2Nexus
APP_ENV=local
APP_KEY=                            # Généré par php artisan key:generate
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=fr
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=fr_FR

APP_MAINTENANCE_DRIVER=file
PHP_CLI_SERVER_WORKERS=4
BCRYPT_ROUNDS=12

# ─── Logs ─────────────────────────────────────────────────────────
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ─── Base de données ──────────────────────────────────────────────
# DB_HOST est surchargé par docker-compose.yml (mysql → nom du service Docker)
# En dehors de Docker, utiliser 127.0.0.1
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=gw2nexus
DB_USERNAME=gw2nexus_user
DB_PASSWORD=                        # Même valeur que DB_PASSWORD dans .env racine

# ─── Cache & Sessions ─────────────────────────────────────────────
CACHE_STORE=database
CACHE_PREFIX=gw2nexus_

# ─── Sessions ─────────────────────────────────────────────────────
# Configuration Sanctum SPA — cookie de session httpOnly
# SESSION_DOMAIN : domaine partagé entre Laravel et React
# SANCTUM_STATEFUL_DOMAINS : liste des domaines autorisés à envoyer des cookies
SESSION_DRIVER=cookie
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=localhost
SESSION_SAME_SITE=lax
SESSION_SECURE_COOKIE=false

SANCTUM_STATEFUL_DOMAINS=localhost:5173,127.0.0.1:5173

# ─── File système ─────────────────────────────────────────────────
FILESYSTEM_DISK=local

# ─── Queue ────────────────────────────────────────────────────────
QUEUE_CONNECTION=database

# ─── Mail ─────────────────────────────────────────────────────────
# MAIL_HOST est surchargé par docker-compose.yml (mailpit → nom du service Docker)
# En dehors de Docker, utiliser localhost
MAIL_MAILER=smtp
MAIL_HOST=127.0.0.1
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=no-reply@gw2nexus.local
MAIL_FROM_NAME="${APP_NAME}"

# ─── Frontend ─────────────────────────────────────────────────────
# URL du frontend React — utilisée par Sanctum pour les CORS et redirections
FRONTEND_URL=http://localhost:5173

# ─── API Guild Wars 2 ─────────────────────────────────────────────
# URL de base de l'API officielle GW2
# Documentation : https://wiki.guildwars2.com/wiki/API:Main
GW2_API_BASE_URL=https://api.guildwars2.com/v2
GW2_API_TIMEOUT=10                  # Timeout en secondes pour les appels HTTP

# ─── Chiffrement clé API GW2 ──────────────────────────────────────
# Laravel utilise APP_KEY pour chiffrer les colonnes encrypted
# La colonne api_key dans la table users est chiffrée via AES-256
# Aucune variable supplémentaire n'est nécessaire — APP_KEY suffit
