<?xml version="1.0" encoding="UTF-8"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="vendor/phpunit/phpunit/phpunit.xsd"
         bootstrap="vendor/autoload.php"
         colors="true"
         stopOnFailure="false"
>
    <testsuites>
        <testsuite name="Unit">
            <directory>tests/Unit</directory>
        </testsuite>
        <testsuite name="Feature">
            <directory>tests/Feature</directory>
        </testsuite>
    </testsuites>

    <source>
        <include>
            <directory>app</directory>
        </include>
    </source>

    <php>
        <!-- Environnement de test isolÃ© -->
        <env name="APP_ENV"          value="testing"/>
        <env name="APP_DEBUG"        value="true"/>

        <!--
        | APP_KEY : obligatoire pour le cast 'encrypted' sur la colonne api_key.
        | Sans cette clÃ©, toute instanciation de User plante en 500.
        -->
        <env name="APP_KEY"          value="base64:I856Ytd3PzMZ7mltYMUUC9QRumCv8w45r9Hs/Byw+fQ="/>

        <!--
        | Base de test en memoire.
        | Cette configuration rend `php artisan test` executable hors Docker
        | sans dependre du service MySQL ni du nom DNS `mysql`.
        -->
        <env name="DB_CONNECTION"    value="sqlite"/>
        <env name="DB_DATABASE"      value=":memory:"/>

        <!--
        | Drivers en mÃ©moire â€” isolation complÃ¨te des services externes.
        | Aucun appel Redis, SMTP ou queue rÃ©el pendant les tests.
        -->
        <env name="CACHE_STORE"      value="array"/>
        <env name="SESSION_DRIVER"   value="array"/>
        <env name="QUEUE_CONNECTION" value="sync"/>
        <env name="MAIL_MAILER"      value="array"/>
    </php>
</phpunit>
