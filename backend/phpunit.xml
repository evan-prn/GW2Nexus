<?xml version="1.0" encoding="UTF-8"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="vendor/phpunit/phpunit/phpunit.xsd"
         bootstrap="vendor/autoload.php"
         colors="true"
         stopOnFailure="false"
>
    <testsuites>
        <testsuite name="Unit">
            <directory>tests/Unit</directory>
        </testsuite>
        <testsuite name="Feature">
            <directory>tests/Feature</directory>
        </testsuite>
    </testsuites>

    <source>
        <include>
            <directory>app</directory>
        </include>
    </source>

    <php>
        <!-- Environnement de test isole -->
        <env name="APP_ENV"          value="testing" force="true"/>
        <env name="APP_DEBUG"        value="true" force="true"/>

        <!--
        | APP_KEY : obligatoire pour le cast 'encrypted' sur la colonne api_key.
        | Sans cette cle, toute instanciation de User plante en 500.
        -->
        <env name="APP_KEY"          value="base64:I856Ytd3PzMZ7mltYMUUC9QRumCv8w45r9Hs/Byw+fQ=" force="true"/>

        <!--
        | Base de test en memoire.
        | Cette configuration rend `php artisan test` executable hors Docker
        | sans dependre du service MySQL ni du nom DNS `mysql`.
        -->
        <env name="DB_CONNECTION"    value="sqlite" force="true"/>
        <env name="DB_DATABASE"      value=":memory:" force="true"/>

        <!--
        | Drivers en memoire - isolation complete des services externes.
        | Aucun appel Redis, SMTP ou queue reel pendant les tests.
        -->
        <env name="CACHE_STORE"      value="array" force="true"/>
        <env name="SESSION_DRIVER"   value="array" force="true"/>
        <env name="QUEUE_CONNECTION" value="sync" force="true"/>
        <env name="MAIL_MAILER"      value="array" force="true"/>

        <!--
        | Docker expose aussi ses variables dans $_SERVER.
        | Laravel consulte cette source avant getenv(), donc les valeurs de test
        | doivent etre imposees dans les deux emplacements.
        -->
        <server name="APP_ENV"          value="testing"/>
        <server name="APP_DEBUG"        value="true"/>
        <server name="APP_KEY"          value="base64:I856Ytd3PzMZ7mltYMUUC9QRumCv8w45r9Hs/Byw+fQ="/>
        <server name="DB_CONNECTION"    value="sqlite"/>
        <server name="DB_DATABASE"      value=":memory:"/>
        <server name="CACHE_STORE"      value="array"/>
        <server name="SESSION_DRIVER"   value="array"/>
        <server name="QUEUE_CONNECTION" value="sync"/>
        <server name="MAIL_MAILER"      value="array"/>
    </php>
</phpunit>
