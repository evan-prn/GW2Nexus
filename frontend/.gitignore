# ═══════════════════════════════════════════════════════════════════
# GW2Nexus — .gitignore Frontend (React/Vite/TypeScript)
# Emplacement : frontend/.gitignore
# ═══════════════════════════════════════════════════════════════════

# ───────────────────────────────────────────────────────────────────
# VARIABLES D'ENVIRONNEMENT
# ───────────────────────────────────────────────────────────────────
.env
.env.*
# Template sans secrets — commité
!.env.example

# ───────────────────────────────────────────────────────────────────
# DÉPENDANCES
# ───────────────────────────────────────────────────────────────────
node_modules/

# ───────────────────────────────────────────────────────────────────
# BUILD & COMPILATION
# ───────────────────────────────────────────────────────────────────
# Build Vite de production (généré par npm run build)
dist/
# Build SSR si activé un jour
dist-ssr/
# Cache interne Vite
.vite/

# ───────────────────────────────────────────────────────────────────
# TYPESCRIPT
# ───────────────────────────────────────────────────────────────────
# Cache de compilation TypeScript incrémentale
*.tsbuildinfo

# ───────────────────────────────────────────────────────────────────
# LOGS
# ───────────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ───────────────────────────────────────────────────────────────────
# IDE & ÉDITEURS
# ───────────────────────────────────────────────────────────────────
.vscode/*
# Exception : recommandations d'extensions partagées
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*.swo

# ───────────────────────────────────────────────────────────────────
# SYSTÈME D'EXPLOITATION
# ───────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini