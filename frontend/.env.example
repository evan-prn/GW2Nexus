# ═══════════════════════════════════════════════════════════════════
# GW2Nexus — frontend/.env.example
# Variables d'environnement Vite (React/TypeScript)
#
# IMPORTANT : seules les variables préfixées VITE_ sont exposées
# au code client. Ne jamais mettre de secrets ici.
#
# 1. Copier ce fichier : cp .env.example .env
# ═══════════════════════════════════════════════════════════════════

# ─── URL de l'API ─────────────────────────────────────────────────
# Grâce au proxy Vite (vite.config.ts), les appels /api/* et /sanctum/*
# sont redirigés vers Laravel sans passer par localhost:8000 directement.
# Cela évite les problèmes CORS et de cookies cross-domain.
VITE_API_URL=http://localhost:5173

# ─── Nom de l'application ─────────────────────────────────────────
VITE_APP_NAME=GW2Nexus
