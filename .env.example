# ═══════════════════════════════════════════════════════════════════
# GW2Nexus — .env racine
# Variables utilisées UNIQUEMENT par docker-compose.yml
# Ce fichier ne concerne pas Laravel ni Vite
#
# 1. Copier ce fichier : cp .env.example .env
# 2. Remplir les valeurs manquantes
# 3. Ne jamais commiter .env (il est dans .gitignore)
# ═══════════════════════════════════════════════════════════════════

# ─── Base de données ──────────────────────────────────────────────
# Ces variables alimentent le service mysql dans docker-compose.yml
# Elles doivent correspondre exactement aux valeurs dans backend/.env
DB_DATABASE=gw2nexus
DB_USERNAME=gw2nexus_user
DB_PASSWORD=
DB_ROOT_PASSWORD=

# ─── Utilisateur hôte ─────────────────────────────────────────────
# Utilisé pour aligner les permissions du volume mount Laravel
# Obtenir son UID/GID : id -u && id -g
# Sur Linux : généralement 1000/1000
# Sur Mac/Windows avec Docker Desktop : laisser 1000/1000
UID=1000
GID=1000
