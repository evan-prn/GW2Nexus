# GW2Nexus - Docker Compose environment example
#
# Copy this file to `.env` at the project root before running Docker Compose.
# These variables are consumed by `docker-compose.yml` only.
# They are not the Laravel or Vite runtime environment files.

# Database used by the MySQL container.
# Inside Docker, MySQL listens on mysql:3306.
# From the host machine, docker-compose.yml publishes it on localhost:3307.
DB_CONNECTION=mysql
DB_DATABASE=gw2nexus
DB_USERNAME=gw2nexus_user
DB_PASSWORD=change_me_dev_password
DB_ROOT_PASSWORD=change_me_root_password

# Host user mapping for the Laravel bind mount.
# Defaults are suitable for Docker Desktop on Windows/macOS.
UID=1000
GID=1000

# Meilisearch master key — shared between the meilisearch container
# and backend/.env (MEILISEARCH_KEY must match this value).
MEILI_MASTER_KEY=change_me_meilisearch_master_key
