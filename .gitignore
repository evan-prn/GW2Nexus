# ═══════════════════════════════════════════════════════════════════
# GW2Nexus — .gitignore racine
# ═══════════════════════════════════════════════════════════════════

# ─── Variables d'environnement ───────────────────────────────────────
# Jamais commiter les .env — ils contiennent des secrets
.env
backend/.env
frontend/.env

# ─── Dépendances ─────────────────────────────────────────────────────
node_modules/
vendor/

# ─── IDE & OS ────────────────────────────────────────────────────────
.idea/
.vscode/
*.DS_Store
Thumbs.db

# ─── Docker ──────────────────────────────────────────────────────────
# Les volumes Docker sont gérés par Docker, pas Git
docker/volumes/